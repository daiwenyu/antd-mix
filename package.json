{
  "name": "antd-mix",
  "version": "0.0.12",
  "homepage": "http://gooccby.gitee.io/antd-mix",
  "repository": "https://gitee.com/gooccby/antd-mix.git",
  "bugs": "https://gitee.com/gooccby/antd-mix/issues",
  "scripts": {
    "start": "dumi dev",
    "docs:build": "dumi build",
    "docs:deploy": "gh-pages -d docs-dist",
    "build": "father-build",
    "deploy": "npm run docs:build && npm run docs:deploy",
    "release": "npm run build && npm publish --registry https://registry.npmjs.org",
    "prettier": "prettier --write \"**/*.{js,jsx,tsx,ts,less,md,json}\"",
    "test": "umi-test",
    "test:coverage": "umi-test --coverage"
  },
  "main": "dist/index.js",
  "module": "dist/index.esm.js",
  "typings": "dist/index.d.ts",
  "gitHooks": {
    "pre-commit": "lint-staged"
  },
  "lint-staged": {
    "*.{js,jsx,less,md,json}": [
      "prettier --write"
    ],
    "*.ts?(x)": [
      "prettier --parser=typescript --write"
    ]
  },
  "peerDependencies": {
    "@ant-design/icons": ">=4.7.0",
    "antd": ">=4.16.13",
    "react": ">=17.0.2"
  },
  "dependencies": {
    "@ant-design/icons": "^4.7.0",
    "antd": "^4.16.13",
    "antd-img-crop": "^3.16.0",
    "lodash": "^4.17.21",
    "react": "^17.0.2"
  },
  "devDependencies": {
    "@types/lodash": "^4.14.175",
    "@umijs/test": "^3.5.20",
    "babel-plugin-import": "^1.13.3",
    "dumi": "^1.1.30",
    "father-build": "^1.20.1",
    "gh-pages": "^3.2.3",
    "lint-staged": "^11.2.3",
    "prettier": "^2.4.1",
    "yorkie": "^2.0.0"
  }
}
